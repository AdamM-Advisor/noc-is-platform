APP_ENV=development

# Frontend/API boundary
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:5174
COOKIE_SECURE=0
COOKIE_SAMESITE=lax
SESSION_COOKIE_DOMAIN=

# Admin bootstrap for local development.
# Use real secrets through Secret Manager in production.
SESSION_SECRET=replace-with-local-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=replace-with-sha256-password-hash

# Local operational paths
NOCIS_DATA_DIR=.data
NOCIS_DB_PATH=.data/noc_analytics.duckdb
NOCIS_UPLOAD_DIR=.uploads
NOCIS_BACKUP_DIR=.data/backups
NOCIS_CHUNK_DIR=temp_chunks
NOCIS_EXPORT_DIR=exports

# Parquet lake root.
# Local example: .parquet_lake
# Google Cloud example: gs://your-bucket/nocis-lake
NOCIS_LAKE_ROOT=.parquet_lake

# Set to 1 in Cloud Run Jobs if the DuckDB image needs to install/load httpfs.
NOCIS_DUCKDB_INSTALL_EXTENSIONS=0

# Optional in Google Cloud runtimes; Cloud Run normally uses service account identity.
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
